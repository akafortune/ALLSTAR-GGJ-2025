    - target: {fileID: 8647974586013353549, guid: 568bae34bf572244fa088c8b2ab5d7f7, type: 3}
      propertyPath: speakSpeed
      value: 0.01
      objectReference: {fileID: 0}
    - target: {fileID: 8647974586013353549, guid: 568bae34bf572244fa088c8b2ab5d7f7, type: 3}
      propertyPath: sceneToLoad
      value: Level 2
      objectReference: {fileID: 0}
    - target: {fileID: 8647974586013353549, guid: 568bae34bf572244fa088c8b2ab5d7f7, type: 3}
      propertyPath: dialogue.Array.size
      value: 7
      objectReference: {fileID: 0}
    - target: {fileID: 8647974586013353549, guid: 568bae34bf572244fa088c8b2ab5d7f7, type: 3}
      propertyPath: dialogue.Array.data[0]
      value: Hey! Took you long you enough to pick up! Har Har Har
      objectReference: {fileID: 0}
    - target: {fileID: 8647974586013353549, guid: 568bae34bf572244fa088c8b2ab5d7f7, type: 3}
      propertyPath: dialogue.Array.data[1]
      value: You're goin up, yeah? Well, listen - I heard they got REAL burgers up
        there
      objectReference: {fileID: 0}
    - target: {fileID: 8647974586013353549, guid: 568bae34bf572244fa088c8b2ab5d7f7, type: 3}
      propertyPath: dialogue.Array.data[2]
      value: Beef patties. No krill added. The real deal
      objectReference: {fileID: 0}
    - target: {fileID: 8647974586013353549, guid: 568bae34bf572244fa088c8b2ab5d7f7, type: 3}
      propertyPath: dialogue.Array.data[3]
      value: And ya know I'm on a sea cow diet, right?
      objectReference: {fileID: 0}
    - target: {fileID: 8647974586013353549, guid: 568bae34bf572244fa088c8b2ab5d7f7, type: 3}
      propertyPath: dialogue.Array.data[4]
      value: I see cow ... and then I eat it!!! Har Har Har!!!
      objectReference: {fileID: 0}
    - target: {fileID: 8647974586013353549, guid: 568bae34bf572244fa088c8b2ab5d7f7, type: 3}
      propertyPath: dialogue.Array.data[5]
      value: So, yeah. I'm gonna need you to grab me one ... or two
      objectReference: {fileID: 0}
    - target: {fileID: 8647974586013353549, guid: 568bae34bf572244fa088c8b2ab5d7f7, type: 3}
      propertyPath: dialogue.Array.data[6]
      value: I'll let you go. But call me back sometime, will ya?
      objectReference: {fileID: 0}
